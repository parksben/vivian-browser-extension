{
  "name": "clawtab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Connect your browser to an OpenClaw Gateway, enabling AI agents to observe and control browser tabs.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "pack:crx": "node scripts/pack-crx.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "crx3": "^2.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
